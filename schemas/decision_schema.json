{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hyunmin625/pepper_smartfarm_plan_v2/schemas/decision_schema.json",
  "title": "Pepper Smartfarm Decision Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "request_id",
    "created_at",
    "farm_id",
    "zone_id",
    "task_type",
    "runtime_mode",
    "status",
    "model_id",
    "prompt_version",
    "state_snapshot",
    "action_payload",
    "policy_summary",
    "validator_summary",
    "citations",
    "retrieval_context",
    "audit_refs"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "decision.v1"
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "farm_id": {
      "type": "string",
      "minLength": 1
    },
    "zone_id": {
      "type": "string",
      "minLength": 1
    },
    "task_type": {
      "type": "string",
      "enum": ["zone_evaluation", "robot_prioritization", "shadow_review", "operator_replay", "alert_summary"]
    },
    "runtime_mode": {
      "type": "string",
      "enum": ["shadow", "approval", "auto", "manual", "simulation"]
    },
    "status": {
      "type": "string",
      "enum": ["evaluated", "approval_requested", "blocked", "approved", "rejected", "executed", "failed", "shadow_logged"]
    },
    "model_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt_version": {
      "type": "string",
      "minLength": 1
    },
    "state_snapshot": {
      "$ref": "state_schema.json"
    },
    "action_payload": {
      "$ref": "action_schema.json"
    },
    "policy_summary": {
      "$ref": "#/$defs/policy_summary"
    },
    "validator_summary": {
      "$ref": "#/$defs/validator_summary"
    },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "action_schema.json#/$defs/citation"
      }
    },
    "retrieval_context": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "state_schema.json#/$defs/retrieved_chunk"
      }
    },
    "generated_requests": {
      "type": "array",
      "items": {
        "$ref": "device_command_request_schema.json"
      }
    },
    "robot_candidates": {
      "type": "array",
      "items": {
        "$ref": "domain_models_schema.json#/$defs/robot_candidate"
      }
    },
    "robot_tasks": {
      "type": "array",
      "items": {
        "$ref": "domain_models_schema.json#/$defs/robot_task"
      }
    },
    "alerts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/alert_summary"
      }
    },
    "approval_request": {
      "anyOf": [
        {
          "$ref": "#/$defs/approval_request"
        },
        {
          "type": "null"
        }
      ]
    },
    "audit_refs": {
      "$ref": "#/$defs/audit_refs"
    }
  },
  "$defs": {
    "policy_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["final_result", "policy_ids", "reason_codes"],
      "properties": {
        "final_result": {
          "type": "string",
          "enum": ["pass", "approval_required", "blocked", "not_evaluated"]
        },
        "policy_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_version": {
          "type": ["string", "null"]
        }
      }
    },
    "validator_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validator_status", "rewritten", "reason_codes"],
      "properties": {
        "validator_status": {
          "type": "string",
          "enum": ["pass", "rewritten", "blocked", "approval_required", "failed"]
        },
        "rewritten": {
          "type": "boolean"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validator_version": {
          "type": ["string", "null"]
        }
      }
    },
    "alert_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alert_id", "alert_type", "severity", "status", "summary"],
      "properties": {
        "alert_id": {
          "type": "string"
        },
        "alert_type": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "critical"]
        },
        "status": {
          "type": "string",
          "enum": ["open", "queued", "resolved", "dismissed"]
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "approval_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approval_id", "approval_scope", "approval_reason", "requested_at", "status"],
      "properties": {
        "approval_id": {
          "type": "string"
        },
        "approval_scope": {
          "type": "string",
          "enum": ["zone", "site", "device", "robot_task", "override"]
        },
        "approval_reason": {
          "type": "string"
        },
        "requested_at": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"]
        }
      }
    },
    "audit_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audit_path"],
      "properties": {
        "audit_path": {
          "type": "string",
          "minLength": 1
        },
        "raw_output_path": {
          "type": ["string", "null"]
        },
        "validated_output_path": {
          "type": ["string", "null"]
        },
        "policy_event_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
