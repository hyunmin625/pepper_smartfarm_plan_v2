{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pepper-smartfarm-plan-v2.local/schemas/sensor_catalog_schema.json",
  "title": "Sensor Catalog",
  "type": "object",
  "required": ["catalog_version", "zones", "sensors", "devices"],
  "properties": {
    "catalog_version": {
      "type": "string",
      "minLength": 1
    },
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["zone_id", "zone_type", "priority", "description"],
        "properties": {
          "zone_id": { "type": "string", "minLength": 1 },
          "zone_type": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "enum": ["must_have", "should_have", "optional"] },
          "description": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "sensors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sensor_id",
          "zone_id",
          "sensor_type",
          "measurement_fields",
          "unit",
          "raw_sample_seconds",
          "ai_aggregation_seconds",
          "priority",
          "quality_flags",
          "model_profile",
          "protocol",
          "install_location",
          "calibration_interval_days",
          "redundancy_group"
        ],
        "properties": {
          "sensor_id": { "type": "string", "minLength": 1 },
          "zone_id": { "type": "string", "minLength": 1 },
          "sensor_type": { "type": "string", "minLength": 1 },
          "measurement_fields": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "unit": { "type": "string", "minLength": 1 },
          "raw_sample_seconds": { "type": "integer", "minimum": 1 },
          "ai_aggregation_seconds": { "type": "integer", "minimum": 1 },
          "priority": { "type": "string", "enum": ["must_have", "should_have", "optional"] },
          "quality_flags": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "model_profile": { "type": "string", "minLength": 1 },
          "protocol": { "type": "string", "minLength": 1 },
          "install_location": { "type": "string", "minLength": 1 },
          "calibration_interval_days": { "type": "integer", "minimum": 1 },
          "redundancy_group": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "device_id",
          "zone_id",
          "device_type",
          "status_sample_seconds",
          "priority",
          "model_profile",
          "protocol",
          "control_mode",
          "response_timeout_seconds",
          "safety_interlocks",
          "install_location"
        ],
        "properties": {
          "device_id": { "type": "string", "minLength": 1 },
          "zone_id": { "type": "string", "minLength": 1 },
          "device_type": { "type": "string", "minLength": 1 },
          "status_sample_seconds": { "type": "integer", "minimum": 1 },
          "priority": { "type": "string", "enum": ["must_have", "should_have", "optional"] },
          "model_profile": { "type": "string", "minLength": 1 },
          "protocol": { "type": "string", "minLength": 1 },
          "control_mode": { "type": "string", "minLength": 1 },
          "response_timeout_seconds": { "type": "integer", "minimum": 1 },
          "safety_interlocks": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "install_location": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
