{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hyunmin625/pepper_smartfarm_plan_v2/schemas/action_schema.json",
  "title": "Pepper Smartfarm AI Recommended Action",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "created_at",
    "farm_id",
    "zone_id",
    "situation_summary",
    "risk_level",
    "recommended_actions",
    "requires_human_approval",
    "follow_up",
    "confidence",
    "citations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "action.v1"
    },
    "decision_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "farm_id": {
      "type": "string"
    },
    "zone_id": {
      "type": "string"
    },
    "situation_summary": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical", "unknown"]
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommended_action"
      }
    },
    "robot_tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/robot_task"
      }
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "approval_reason": {
      "type": ["string", "null"]
    },
    "follow_up": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/follow_up"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "retrieval_coverage": {
      "type": "string",
      "enum": ["sufficient", "partial", "insufficient", "not_used"]
    },
    "citations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/citation"
      }
    },
    "policy_precheck": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policy_precheck"
      }
    }
  },
  "$defs": {
    "recommended_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_type", "target", "risk_level", "approval_required", "reason"],
      "properties": {
        "action_id": {
          "type": "string"
        },
        "action_type": {
          "type": "string",
          "enum": [
            "observe_only",
            "create_alert",
            "request_human_check",
            "adjust_fan",
            "adjust_shade",
            "adjust_vent",
            "short_irrigation",
            "adjust_fertigation",
            "adjust_heating",
            "adjust_co2",
            "pause_automation",
            "enter_safe_mode",
            "create_robot_task",
            "block_action"
          ]
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target_type", "target_id"],
          "properties": {
            "target_type": {
              "type": "string",
              "enum": ["zone", "device", "sensor", "robot", "operator", "system"]
            },
            "target_id": {
              "type": "string"
            }
          }
        },
        "parameters": {
          "type": "object",
          "description": "Action-specific parameters. Must be validated again by execution-gateway."
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical", "unknown"]
        },
        "approval_required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "expected_effect": {
          "type": ["string", "null"]
        },
        "cooldown_minutes": {
          "type": ["number", "null"],
          "minimum": 0
        }
      }
    },
    "robot_task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_type", "priority", "approval_required", "reason"],
      "properties": {
        "task_type": {
          "type": "string",
          "enum": ["harvest_candidate_review", "inspect_crop", "skip_area", "manual_review"]
        },
        "candidate_id": {
          "type": ["string", "null"]
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "urgent"]
        },
        "approval_required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "follow_up": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_type", "due_in_minutes", "description"],
      "properties": {
        "check_type": {
          "type": "string",
          "enum": ["sensor_recheck", "visual_inspection", "device_readback", "operator_confirm", "trend_review", "lab_test", "other"]
        },
        "due_in_minutes": {
          "type": "number",
          "minimum": 0
        },
        "description": {
          "type": "string"
        }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_id", "chunk_id"],
      "properties": {
        "document_id": {
          "type": "string"
        },
        "chunk_id": {
          "type": "string"
        },
        "source_url": {
          "type": ["string", "null"]
        }
      }
    },
    "policy_precheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_id", "result", "reason"],
      "properties": {
        "policy_id": {
          "type": "string"
        },
        "result": {
          "type": "string",
          "enum": ["pass", "approval_required", "blocked", "not_evaluated"]
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
