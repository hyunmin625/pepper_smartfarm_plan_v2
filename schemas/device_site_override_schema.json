{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pepper-smartfarm-plan-v2.local/schemas/device_site_override_schema.json",
  "title": "Device Site Override Map",
  "type": "object",
  "required": [
    "site_id",
    "site_version",
    "registry_version",
    "catalog_version",
    "controllers",
    "device_bindings"
  ],
  "properties": {
    "site_id": { "type": "string", "minLength": 1 },
    "site_version": { "type": "string", "minLength": 1 },
    "registry_version": { "type": "string", "minLength": 1 },
    "catalog_version": { "type": "string", "minLength": 1 },
    "controllers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["controller_id", "protocol", "endpoint", "role"],
        "properties": {
          "controller_id": { "type": "string", "minLength": 1 },
          "protocol": { "type": "string", "minLength": 1 },
          "endpoint": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "device_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "device_id",
          "profile_id",
          "controller_id",
          "protocol",
          "write_channel_ref",
          "read_channel_refs"
        ],
        "properties": {
          "device_id": { "type": "string", "minLength": 1 },
          "profile_id": { "type": "string", "minLength": 1 },
          "controller_id": { "type": "string", "minLength": 1 },
          "protocol": { "type": "string", "minLength": 1 },
          "write_channel_ref": { "type": "string", "minLength": 1 },
          "read_channel_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "command_encoder": { "type": "string", "minLength": 1 },
          "readback_decoder": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
