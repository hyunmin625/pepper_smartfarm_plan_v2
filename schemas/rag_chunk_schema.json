{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hyunmin625/pepper_smartfarm_plan_v2/schemas/rag_chunk_schema.json",
  "title": "Pepper Smartfarm RAG Chunk",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chunk_id",
    "document_id",
    "source_url",
    "source_type",
    "crop_type",
    "growth_stage",
    "cultivation_type",
    "sensor_tags",
    "risk_tags",
    "operation_tags",
    "causality_tags",
    "visual_tags",
    "chunk_summary",
    "agent_use",
    "citation_required"
  ],
  "properties": {
    "chunk_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-[0-9]{3}$"
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "official_master_guideline",
        "official_guideline",
        "official_research_report",
        "field_case",
        "local_extension_news",
        "secondary_agriculture_news",
        "research_paper",
        "internal_design",
        "internal_sop",
        "farm_case"
      ]
    },
    "crop_type": {
      "type": "string",
      "enum": ["red_pepper", "dried_red_pepper", "greenhouse_crops"]
    },
    "growth_stage": {
      "$ref": "#/$defs/string_array"
    },
    "cultivation_type": {
      "$ref": "#/$defs/string_array"
    },
    "sensor_tags": {
      "$ref": "#/$defs/string_array"
    },
    "risk_tags": {
      "$ref": "#/$defs/string_array"
    },
    "operation_tags": {
      "$ref": "#/$defs/string_array"
    },
    "causality_tags": {
      "$ref": "#/$defs/string_array"
    },
    "visual_tags": {
      "$ref": "#/$defs/string_array_allow_empty"
    },
    "source_pages": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        }
      ]
    },
    "source_page": {
      "type": "integer",
      "minimum": 1
    },
    "source_section": {
      "type": "string",
      "minLength": 1
    },
    "trust_level": {
      "type": "string",
      "enum": ["high", "medium", "low", "review_required"]
    },
    "version": {
      "type": "string"
    },
    "effective_date": {
      "type": "string"
    },
    "active": {
      "type": "boolean"
    },
    "region": {
      "$ref": "#/$defs/string_array"
    },
    "season": {
      "$ref": "#/$defs/string_array"
    },
    "cultivar": {
      "$ref": "#/$defs/string_array"
    },
    "greenhouse_type": {
      "$ref": "#/$defs/string_array"
    },
    "farm_id": {
      "type": "string"
    },
    "zone_id": {
      "type": "string"
    },
    "outcome": {
      "type": "string",
      "enum": ["success", "failure", "mixed", "unknown"]
    },
    "chunk_summary": {
      "type": "string",
      "minLength": 20
    },
    "agent_use": {
      "$ref": "#/$defs/string_array"
    },
    "citation_required": {
      "type": "boolean"
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "string_array_allow_empty": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
