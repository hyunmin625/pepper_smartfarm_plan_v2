# Local secrets for OpenAI-backed retrieval and fine-tuned models
OPENAI_API_KEY=

# Ops API LLM client — decision path (evaluate_zone, forbidden_action, robot_task_prioritization 등)
# 기본은 stub. 프로덕션에서는 ds_v11 frozen baseline을 씁니다.
# OPS_API_LLM_PROVIDER=openai
# OPS_API_MODEL_ID=ft:gpt-4.1-mini-2025-04-14:hyunmin:ft-sft-gpt41mini-ds-v11-prompt-v5-methodfix-batch14-eval-v2-2026:DTryNJg3
OPS_API_LLM_PROVIDER=stub
OPS_API_MODEL_ID=pepper-ops-local-stub

# Ops API LLM client — AI 어시스턴트 채팅 경로 (/ai/chat)
# 결정 경로와 독립된 파인튜닝 모델을 지정할 수 있습니다. 미지정 시 OPS_API_LLM_PROVIDER/OPS_API_MODEL_ID로 fallback.
# OPS_API_CHAT_PROVIDER=openai
# OPS_API_CHAT_MODEL_ID=ft:gpt-4.1-mini-2025-04-14:hyunmin:ft-sft-gpt41mini-ds-v14-prompt-v10-validator-aligned-batch19-har:DU2VQVYz
OPS_API_CHAT_PROVIDER=
OPS_API_CHAT_MODEL_ID=

# Ops API auth
# disabled: local dev mode, header_token: require X-API-Key
OPS_API_AUTH_MODE=disabled
# Example:
# OPS_API_AUTH_TOKENS_JSON={"operator-secret":{"actor_id":"operator-01","role":"operator"},"service-secret":{"actor_id":"ops-service","role":"service"}}
OPS_API_AUTH_TOKENS_JSON=

# Runtime PLC endpoint overrides
# Example:
# PLC_ENDPOINT_GH_01_MAIN_PLC=modbus-tcp://192.168.10.20:502
# PLC_ENDPOINT_GH_01_DRY_PLC=modbus-tcp://192.168.10.21:502
PLC_ENDPOINT_GH_01_MAIN_PLC=
PLC_ENDPOINT_GH_01_DRY_PLC=

# Sensor ingestor local outbox backends
SENSOR_INGESTOR_RUNTIME_DIR=artifacts/runtime/sensor_ingestor
SENSOR_INGESTOR_MQTT_OUTBOX_PATH=
SENSOR_INGESTOR_TIMESERIES_OUTBOX_PATH=
SENSOR_INGESTOR_OBJECT_STORE_OUTBOX_PATH=
SENSOR_INGESTOR_ALERT_OUTBOX_PATH=

# Execution gateway local audit log
EXECUTION_GATEWAY_AUDIT_LOG_PATH=artifacts/runtime/execution_gateway/dispatch_audit.jsonl
