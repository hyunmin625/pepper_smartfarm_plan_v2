      "command_family": "percent_output",
      "supported_action_types": ["adjust_fan", "pause_automation"],
      "supported_modes": ["manual", "auto", "disabled"],
      "parameter_specs": [
        { "name": "run_state", "data_type": "string", "required": true, "allowed_values": ["on", "off"] },
        { "name": "speed_pct", "data_type": "integer", "required": false, "unit": "pct", "minimum": 0, "maximum": 100 }
      ],
      "readback_fields": [
        { "field_name": "run_state", "data_type": "string", "required": true },
        { "field_name": "speed_pct", "data_type": "integer", "required": false },
        { "field_name": "fault_code", "data_type": "string", "required": false }
      ],
      "safety_interlocks": ["manual_override", "motor_fault", "estop"],
      "ack_policy": {
        "requires_ack": true,
        "ack_timeout_seconds": 30,
        "verify_readback": true,
        "success_conditions": ["run_state_matches", "speed_pct_within_tolerance"]
      },
      "mapping": {
        "write_channel_type": "plc_register",
        "write_channel_ref": "profile://fan_speed_command",
        "read_channel_refs": ["profile://fan_run_state", "profile://fan_speed_feedback", "profile://fan_fault_code"],
