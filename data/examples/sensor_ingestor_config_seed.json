  "quality_rule_sets": [
    {
      "rule_set_id": "quality-climate-combo",
      "applies_to": [
        "air_temp_rh",
        "co2",
        "par",
        "outside_weather",
        "dry_room_temp_rh"
      ],
      "stale_after_seconds": 90,
      "bad_after_seconds": 300,
      "flatline_window_seconds": 1800,
      "jump_threshold_pct": 25
    },
    {
      "rule_set_id": "quality-rootzone-probe",
      "applies_to": [
        "substrate_moisture",
        "substrate_temp"
      ],
      "stale_after_seconds": 180,
      "bad_after_seconds": 600,
      "flatline_window_seconds": 1800,
      "jump_threshold_pct": 20,
      "allowed_range": {
        "min": 0,
        "max": 100
      }
    },
    {
      "rule_set_id": "quality-liquid-chemistry",
      "applies_to": [
        "feed_ec_ph",
        "drain_ec_ph"
      ],
      "stale_after_seconds": 300,
      "bad_after_seconds": 900,
      "jump_threshold_pct": 30
    },
    {
      "rule_set_id": "quality-liquid-temperature",
      "applies_to": [
        "nutrient_solution_temp",
        "source_water_temp"
      ],
      "stale_after_seconds": 300,
      "bad_after_seconds": 900,
      "jump_threshold_pct": 20
    },
    {
      "rule_set_id": "quality-pulse-counter",
      "applies_to": [
        "drain_volume"
      ],
      "stale_after_seconds": 300,
      "bad_after_seconds": 900,
      "jump_threshold_pct": 100
    },
    {
      "rule_set_id": "quality-vision-frame",
      "applies_to": [
        "crop_image_frame"
      ],
      "stale_after_seconds": 900,
      "bad_after_seconds": 1800
    },
    {
      "rule_set_id": "quality-manual-product-moisture",
      "applies_to": [
        "product_moisture"
      ],
      "stale_after_seconds": 172800,
      "bad_after_seconds": 259200
    }
  ],
