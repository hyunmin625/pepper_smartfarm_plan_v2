    {
      "profile_id": "modbus_rtu_fast_10s",
      "protocol": "rs485_modbus_rtu",
      "poll_interval_seconds": 10,
      "timeout_seconds": 2,
      "retry_count": 2,
      "retry_backoff_seconds": 3,
      "enabled": true
    },
    {
      "profile_id": "modbus_rtu_standard_30s",
      "protocol": "rs485_modbus_rtu",
      "poll_interval_seconds": 30,
      "timeout_seconds": 3,
      "retry_count": 2,
      "retry_backoff_seconds": 5,
      "enabled": true
    },
    {
      "profile_id": "modbus_rtu_slow_60s",
      "protocol": "rs485_modbus_rtu",
      "poll_interval_seconds": 60,
      "timeout_seconds": 5,
      "retry_count": 2,
      "retry_backoff_seconds": 10,
      "enabled": true
    },
    {
      "profile_id": "pulse_counter_60s",
      "protocol": "pulse_counter",
      "poll_interval_seconds": 60,
      "timeout_seconds": 2,
      "retry_count": 1,
      "retry_backoff_seconds": 5,
      "enabled": true
    },
    {
      "profile_id": "rtsp_capture_300s",
      "protocol": "rtsp_onvif",
      "poll_interval_seconds": 300,
      "timeout_seconds": 15,
      "retry_count": 1,
      "retry_backoff_seconds": 30,
      "enabled": true
    },
    {
      "profile_id": "plc_feedback_10s",
      "protocol": "plc_tag_modbus_tcp",
      "poll_interval_seconds": 10,
      "timeout_seconds": 2,
      "retry_count": 2,
      "retry_backoff_seconds": 3,
      "enabled": true
    },
    {
      "profile_id": "manual_batch_daily",
      "protocol": "manual_batch_import",
      "poll_interval_seconds": 86400,
      "timeout_seconds": 30,
      "retry_count": 0,
      "retry_backoff_seconds": 0,
      "enabled": true
    }
  ],
